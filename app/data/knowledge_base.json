    {
      "id": "kb_019",
      "term_cn": "质量因子",
      "term_en": "Quality Factor",
      "category": "factor_system",
      "subcategory": "基本面因子",
      "definition": "衡量公司盈利质量和财务稳定性的因子，包括ROE、ROA、毛利率、净利率等。",
      "formula": null,
      "key_points": [
        "ROE = 净利润/净资产，衡量股东回报率",
        "ROA = 净利润/总资产，衡量资产使用效率",
        "毛利率 = (营收-成本)/营收，衡量定价能力",
        "净利率 = 净利润/营收，衡量整体盈利能力"
      ],
      "related_terms": ["kb_020", "kb_021"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_020",
      "term_cn": "估值因子",
      "term_en": "Value Factor",
      "category": "factor_system",
      "subcategory": "基本面因子",
      "definition": "衡量股票价格相对其基本面价值是否合理的因子，包括PE、PB、PS、PEG等。",
      "formula": "PE = 股价/每股收益, PB = 股价/每股净资产, PS = 股价/每股营收, PEG = PE/盈利增长率",
      "key_points": [
        "低PE/PB通常代表价值被低估",
        "需结合成长性看估值，PEG更全面",
        "EV/EBITDA不受资本结构影响，适合跨行业比较"
      ],
      "related_terms": ["kb_019", "kb_022"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_021",
      "term_cn": "动量因子",
      "term_en": "Momentum Factor",
      "category": "factor_system",
      "subcategory": "量价因子",
      "definition": "基于股票过去一段时间收益率构建的因子，反映价格趋势延续性。",
      "formula": "MOM_N = Price_t / Price_{t-N} - 1",
      "key_points": [
        "常用周期：1月(21日)、3月(63日)、6月(126日)、12月(252日)",
        "A股短期(1月)存在反转效应，中长期(3-12月)存在动量效应",
        "需排除最近1周收益以避免短期反转干扰"
      ],
      "related_terms": ["kb_025", "kb_030"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_022",
      "term_cn": "成长因子",
      "term_en": "Growth Factor",
      "category": "factor_system",
      "subcategory": "基本面因子",
      "definition": "衡量公司业绩增长速度的因子，包括营收同比增长、净利润同比增长等。",
      "formula": "营收YoY = (本期营收 - 上期营收) / |上期营收|",
      "key_points": [
        "同比增长消除季节性影响",
        "高增长不一定好，需结合估值看性价比",
        "成长因子与质量因子可形成互补"
      ],
      "related_terms": ["kb_019", "kb_020"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_023",
      "term_cn": "风险因子",
      "term_en": "Risk Factor",
      "category": "factor_system",
      "subcategory": "量价因子",
      "definition": "衡量股票风险水平的因子，包括波动率、Beta、下行波动率等。",
      "formula": "Beta = Cov(R_i, R_m) / Var(R_m), 下行波动率 = sqrt(mean(min(R_i - 0, 0)^2))",
      "key_points": [
        "高波动率股票风险大但可能收益高",
        "Beta衡量个股相对市场的系统性风险",
        "下行波动率只考虑负收益，更符合投资者对风险的感知"
      ],
      "related_terms": ["kb_024", "kb_068"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_024",
      "term_cn": "流动性因子",
      "term_en": "Liquidity Factor",
      "category": "factor_system",
      "subcategory": "量价因子",
      "definition": "衡量股票交易活跃度和流动性成本的因子，包括Amihud非流动性、换手率等。",
      "formula": "Amihud = mean(|r_t| / VOLD_t), 换手率 = 成交量 / 流通股本",
      "key_points": [
        "Amihud衡量单位成交额引起的价格变动，值越大流动性越差",
        "低流动性股票通常有流动性溢价",
        "换手率过高可能暗示投机过度"
      ],
      "related_terms": ["kb_014", "kb_023"],
      "source_module": "alpha_modules",
      "difficulty": "intermediate"
    },
    {
      "id": "kb_025",
      "term_cn": "反转因子",
      "term_en": "Reversal Factor",
      "category": "factor_system",
      "subcategory": "量价因子",
      "definition": "基于股票短期(通常1个月)收益构建的因子，A股短期存在显著的反转效应。",
      "formula": "REV = -Return_{t-21:t-1}",
      "key_points": [
        "A股1月反转效应显著：上月跌得多的股票本月倾向于反弹",
        "与动量因子方向相反，短期反转 vs 中期动量",
        "反转因子在A股的IC通常高于动量因子"
