# 数据库配置 - SQLite（开发环境）
DATABASE_URL=sqlite:///./quant_platform.db

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 认证配置
SECRET_KEY=your-super-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MinIO 对象存储配置（可选，用于存储报告文件）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=quant-reports

# 数据源配置
# Tushare Token（注册 https://tushare.pro 获取）
TUSHARE_TOKEN=6658293db0944bc93f626b9fd9c8d509fc2fe43e7b4f48fcb1178dda
# 主数据源: crawler(爬虫/免费), akshare(免费), tushare(需积分)
PRIMARY_DATA_SOURCE=crawler

# 应用配置
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
