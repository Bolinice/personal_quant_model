# A股多因子增强策略平台 环境配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库 ====================
DATABASE_URL=postgresql://user:password@localhost:5432/quant_platform
# 开发环境可使用: sqlite:///./quant_platform.db

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== JWT认证 ====================
# 生产环境必须使用强密钥，可用: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Celery ====================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== MinIO对象存储 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_NAME=quant-platform

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== 数据源 ====================
TUSHARE_TOKEN=
PRIMARY_DATA_SOURCE=akshare

# ==================== 应用配置 ====================
DEBUG=false
LOG_LEVEL=INFO
